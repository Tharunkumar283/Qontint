# Qontint — Environment Configuration
# ═══════════════════════════════════════════════════════
# All values have sensible defaults for local development.
# Copy this to .env and fill in your API keys.

# ── App ─────────────────────────────────────────────────
APP_NAME=Qontint
DEBUG=true

# ── Database ────────────────────────────────────────────
# SQLite (default — zero configuration):
DATABASE_URL=sqlite+aiosqlite:///./qontint.db
# PostgreSQL (uncomment and fill when ready):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/qontint

# ── LLM — Claude API (PRIMARY) ──────────────────────────
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# ── LLM — Ollama (SECONDARY fallback, free/local) ───────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── External APIs ────────────────────────────────────────
# Ahrefs API — Primary SERP data source ($99/mo)
# Get key at: https://ahrefs.com/api
AHREFS_API_KEY=

# YouTube Data API v3 — YouTube ranking prediction
# Get key at: https://console.cloud.google.com
YOUTUBE_API_KEY=

# ── Caching — Redis ──────────────────────────────────────
# Falls back to in-memory cache if not set
REDIS_URL=

# ── Graph DB — Neo4j ─────────────────────────────────────
# Falls back to in-memory NetworkX if not set
NEO4J_URI=
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ── Authentication ───────────────────────────────────────
# CHANGE THIS in production!
JWT_SECRET=qontint_jwt_secret_change_in_production

# ── NLP ──────────────────────────────────────────────────
SPACY_MODEL=en_core_web_sm

# ── Thresholds ───────────────────────────────────────────
NOVELTY_THRESHOLD=0.35
SIMILARITY_THRESHOLD=0.40

# ── Defaults ─────────────────────────────────────────────
DEFAULT_VERTICAL=saas
